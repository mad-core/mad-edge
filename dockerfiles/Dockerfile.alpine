FROM alpine:3.20

ARG HOST_UID=501

RUN apk add --no-cache \
    bash \
    curl \
    ca-certificates \
    git \
    libgcc \
    libstdc++ \
    ripgrep

RUN adduser -D -s /bin/bash -u ${HOST_UID} claude

USER claude
WORKDIR /home/claude

RUN curl -fsSL https://claude.ai/install.sh | bash

ENV PATH="/home/claude/.local/bin:${PATH}"

# Skip onboarding wizard (theme picker + login prompt)
RUN echo '{"hasCompletedOnboarding":true,"shiftEnterKeyBindingInstalled":true,"theme":"dark"}' > /home/claude/.claude.json

VOLUME ["/home/claude/.claude"]

ENTRYPOINT ["/bin/bash"]
