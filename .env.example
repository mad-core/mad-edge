# Authentication — choose ONE method:

# Option 1: OAuth token (recommended for Pro/Max subscribers)
# Generate with: claude setup-token (on a machine where you're logged in)
CLAUDE_CODE_OAUTH_TOKEN=

# Option 2: API key (pay-per-token via Anthropic Console)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Host UID — set to match your system user for bind-mount permissions
# macOS default: 501, Linux default: 1000
HOST_UID=501
