# Mad instance configuration — copy to `.env` and edit. NEVER commit the real
# `.env` (it holds tokens); only this `.env.example` is tracked. See docs/docker.md.
#
# All values below are SAFE PLACEHOLDERS. Two groups:
#   1. compose interpolation vars (instance identity, port, build args)
#   2. runtime env injected into the container (secrets + MAD_* tunables)

# ── 1. Instance identity & build ────────────────────────────────────────────

# Instance name. Drives the container name AND the host bind-mount paths
# (./instances/<MAD_INSTANCE>/…), so each instance gets its own workspace and
# credential dirs. Use a different value per instance on the same host.
MAD_INSTANCE=default

# Host port published for this instance's HTTP/MCP API (container always 8000).
# Give each instance a distinct port: 8080, 8081, 8082, …
MAD_HOST_PORT=8080

# mad-bros version baked into the image. Empty = latest published release.
# Pin to an exact release (e.g. 0.5.11) to tie the image to a known version.
MAD_VERSION=

# Host operator's UID/GID. The container user is created with these ids so the
# bind-mounted workspace stays writable AND owned by you on the host. Find yours
# with `id -u` / `id -g` (1000:1000 is the typical first user on a Raspberry Pi).
PUID=1000
PGID=1000

# ── 2. Credentials (runtime, injected into the container) ────────────────────

# GitHub token the LAUNCHED AGENT uses to push commits / open PRs from inside
# the workspace (read by the agent as GH_TOKEN / GITHUB_TOKEN — see auto-sync).
# NOTE on token hygiene (CLAUDE.md hard rule 2): the token used to CLONE a repo
# is delivered per-request in the create-session call and stripped from the git
# remote afterwards — that is separate from this env token. Use a fine-grained
# PAT scoped to only the repos this instance should touch.
GITHUB_TOKEN=ghp_replace_me
GH_TOKEN=ghp_replace_me

# AWS credentials: mounted as a read-only dir at ~/.aws via compose
# (./instances/<MAD_INSTANCE>/aws). Alternatively uncomment to pass them as env
# instead of mounting a dir — then drop the aws volume from the compose file.
# AWS_ACCESS_KEY_ID=replace_me
# AWS_SECRET_ACCESS_KEY=replace_me
# AWS_REGION=us-east-1

# Claude account: NOT configured here. Log in once inside the container so the
# Pro/Max session persists in the mounted ~/.claude dir:
#   docker compose -f compose.example.yml exec mad claude
# (Alternative — API-key billing instead of a Pro/Max login: set ANTHROPIC_API_KEY.)
# ANTHROPIC_API_KEY=sk-ant-replace_me

# ── 3. MAD_* tunables (optional — defaults shown, uncomment to override) ──────

# Workspace base dir INSIDE the container (#64). Pinned to /workspaces by the
# compose file's `environment:` block, which overrides any value set here. You
# normally do NOT change this — to relocate the data on the HOST, change the
# workspace bind-mount source in the compose file instead. Listed here only so
# the full surface is documented.
# MAD_WORKSPACE_DIR=/workspaces

# Agent CLI binaries — already on PATH in the image; override only to pin a path.
# MAD_CLAUDE_CLI_BIN=claude
# MAD_OPENCODE_BIN=opencode

# Per-run agent timeouts in seconds (claude default is the launcher default;
# opencode default is 600). Raise for long agent runs.
# MAD_CLAUDE_CLI_TIMEOUT_S=600
# MAD_OPENCODE_TIMEOUT_S=600

# SSE keep-alive heartbeat interval (seconds) for GET /v1/events/stream.
# MAD_SSE_HEARTBEAT_S=15

# MCP DNS-rebinding protection — comma-separated allowed Host headers. Off by
# default (auth is expected at the edge). Set when exposing /mcp directly.
# MAD_MCP_ALLOWED_HOSTS=localhost,mad.example.com
